{
  "$schema": "../../../schemas/skill-schemas/skill-locale-config.json",
  "actions": {
    "greet": {
      "answers": {
        "greeting": [
          { "text": "I'm Oz, your infrastructure assistant. I can check server health, fetch logs, run commands, deploy projects, and launch AI agents for any system task. What do you need?", "speech": "I'm Oz, your infrastructure assistant. What do you need?" }
        ]
      }
    },
    "run_bash": {
      "answers": {
        "executing": [
          { "text": "Launching an Oz agent to run that command. One moment...", "speech": "Launching an Oz agent to run that command. One moment." }
        ],
        "still_working": [
          { "text": "⏳ {{ message }}", "speech": "Still working, please wait." }
        ],
        "launched": [
          { "text": "Agent <strong>#{{ agent_id }}</strong> — status: <strong>{{ status }}</strong>.", "speech": "Agent {{ agent_id }}, status {{ status }}." }
        ],
        "result": [
          { "text": "<div>{{ logs }}</div>", "speech": "Here's the output." }
        ],
        "error": [
          { "text": "Sorry, something went wrong: {{ message }}", "speech": "Sorry, something went wrong." }
        ],
        "no_command": [
          { "text": "What command would you like me to run?", "speech": "What command would you like me to run?" }
        ]
      }
    },
    "server_health": {
      "answers": {
        "checking_health": [
          { "text": "<p style=\"color:#94a3b8;font-size:13px;margin:4px 0\">🖥️ Checking health of <strong>{{ server }}</strong>…</p>", "speech": "Checking server health. One moment." }
        ],
        "still_working": [
          { "text": "<p style=\"color:#94a3b8;font-size:13px;margin:4px 0\">⏳ {{ message }}</p>", "speech": "Still working, please wait." }
        ],
        "health_result": [
          { "text": "{{ logs }}", "speech": "Here is the health report." }
        ],
        "error": [
          { "text": "<div style=\"background:#fef2f2;border:1px solid #fca5a5;border-radius:6px;padding:10px 14px;color:#dc2626;font-size:13px\">❌ {{ message }}</div>", "speech": "Failed to check server health." }
        ]
      }
    },
    "app_logs": {
      "answers": {
        "fetching_logs": [
          { "text": "Fetching application logs from <strong>{{ server }}</strong>...", "speech": "Fetching application logs. One moment." }
        ],
        "still_working": [
          { "text": "⏳ {{ message }}", "speech": "Still working, please wait." }
        ],
        "logs_result": [
          { "text": "<div>{{ logs }}</div>", "speech": "Here are the logs." }
        ],
        "error": [
          { "text": "Failed to fetch logs: {{ message }}", "speech": "Failed to fetch logs." }
        ]
      }
    },
    "proxmox": {
      "answers": {
        "fetching_proxmox": [
          { "text": "<p style=\"color:#94a3b8;font-size:13px;margin:4px 0\">🖥️ Querying Proxmox on <strong>{{ server }}</strong>…</p>", "speech": "Querying Proxmox. One moment." }
        ],
        "still_working": [
          { "text": "<p style=\"color:#94a3b8;font-size:13px;margin:4px 0\">⏳ {{ message }}</p>", "speech": "Still working, please wait." }
        ],
        "proxmox_result": [
          { "text": "{{ logs }}", "speech": "Here are the Proxmox results." }
        ],
        "error": [
          { "text": "<div style=\"background:#fef2f2;border:1px solid #fca5a5;border-radius:6px;padding:10px 14px;color:#dc2626;font-size:13px\">❌ {{ message }}</div>", "speech": "Failed to query Proxmox." }
        ]
      }
    },
    "docker_logs": {
      "answers": {
        "fetching_docker_logs": [
          { "text": "<p style=\"color:#94a3b8;font-size:13px;margin:4px 0\">🐳 Fetching Docker info for <strong>{{ container }}</strong> on <strong>{{ server }}</strong>…</p>", "speech": "Fetching Docker info. One moment." }
        ],
        "still_working": [
          { "text": "<p style=\"color:#94a3b8;font-size:13px;margin:4px 0\">⏳ {{ message }}</p>", "speech": "Still working, please wait." }
        ],
        "docker_logs_result": [
          { "text": "{{ logs }}", "speech": "Here are the Docker results." }
        ],
        "error": [
          { "text": "<div style=\"background:#fef2f2;border:1px solid #fca5a5;border-radius:6px;padding:10px 14px;color:#dc2626;font-size:13px\">❌ {{ message }}</div>", "speech": "Failed to fetch Docker info." }
        ]
      }
    },
    "deploy": {
      "answers": {
        "deploying": [
          { "text": "Starting deployment of <strong>{{ path }}</strong> on <strong>{{ server }}</strong>. This may take a few minutes...", "speech": "Starting deployment. This may take a few minutes." }
        ],
        "still_working": [
          { "text": "⏳ {{ message }}", "speech": "Still working, please wait." }
        ],
        "deploy_result": [
          { "text": "<div>{{ logs }}</div>", "speech": "Deployment finished. Status: {{ status }}." }
        ],
        "no_path": [
          { "text": "Please specify the project path to deploy. For example: deploy /var/www/myapp on prod-web.", "speech": "Please specify the project path to deploy." }
        ],
        "error": [
          { "text": "Deployment failed: {{ message }}", "speech": "Deployment failed." }
        ]
      }
    },
    "launch_agent": {
      "answers": {
        "launching": [
          { "text": "Launching a <strong>{{ agent_type }}</strong> agent. One moment...", "speech": "Launching an Oz agent. One moment." }
        ],
        "still_working": [
          { "text": "⏳ {{ message }}", "speech": "Still working, please wait." }
        ],
        "launched": [
          { "text": "Agent <strong>#{{ agent_id }}</strong> — status: <strong>{{ status }}</strong>.", "speech": "Agent {{ agent_id }}, status {{ status }}." }
        ],
        "result": [
          { "text": "{{ files_html }}<div>{{ logs }}</div>", "speech": "Here's what the agent found." }
        ],
        "error": [
          { "text": "Sorry, I couldn't launch the agent: {{ message }}", "speech": "Sorry, I couldn't launch the agent." }
        ],
        "no_prompt": [
          { "text": "What task would you like the agent to do? Please describe it.", "speech": "What task would you like the agent to do?" }
        ]
      }
    },
    "list_agents": {
      "answers": {
        "listing": [
          { "text": "Let me check the recent agent runs...", "speech": "Let me check the recent agent runs." }
        ],
        "empty": [
          { "text": "No agent runs found.", "speech": "No agent runs found." }
        ],
        "list": [
          { "text": "Recent agent runs:<br><br>{{ agents }}", "speech": "Here are the recent runs." }
        ],
        "error": [
          { "text": "Couldn't fetch the agent list: {{ message }}", "speech": "Couldn't fetch the agent list." }
        ]
      }
    },
    "get_agent": {
      "answers": {
        "fetching": [
          { "text": "Let me check on that agent run...", "speech": "Let me check on that agent run." }
        ],
        "not_found": [
          { "text": "Agent run #{{ agent_id }} was not found.", "speech": "Agent run {{ agent_id }} was not found." }
        ],
        "detail": [
          { "text": "Agent <strong>#{{ agent_id }}</strong><br>Type: {{ type }}<br>Status: <strong>{{ status }}</strong><br>Created: {{ created }}<br><br>{{ logs_block }}", "speech": "Agent {{ agent_id }}. Type: {{ type }}. Status: {{ status }}." }
        ],
        "error": [
          { "text": "Couldn't fetch agent details: {{ message }}", "speech": "Couldn't fetch agent details." }
        ]
      }
    },
    "cancel_agent": {
      "answers": {
        "cancelling": [
          { "text": "Cancelling agent run...", "speech": "Cancelling agent run." }
        ],
        "cancelled": [
          { "text": "Agent #{{ agent_id }} has been cancelled.", "speech": "Agent {{ agent_id }} has been cancelled." }
        ],
        "not_found": [
          { "text": "Agent #{{ agent_id }} was not found.", "speech": "Agent {{ agent_id }} was not found." }
        ],
        "error": [
          { "text": "Couldn't cancel the agent: {{ message }}", "speech": "Couldn't cancel the agent." }
        ]
      }
    },
    "check_website": {
      "answers": {
        "checking": [
          { "text": "Checking <strong>{{ url }}</strong> from <strong>{{ server }}</strong>. One moment...", "speech": "Checking website status. One moment." }
        ],
        "still_working": [
          { "text": "⏳ {{ message }}", "speech": "Still working, please wait." }
        ],
        "result": [
          { "text": "<div>{{ logs }}</div>", "speech": "Here is the website status." }
        ],
        "error": [
          { "text": "Failed to check website: {{ message }}", "speech": "Failed to check website." }
        ]
      }
    },
    "list_servers": {
      "answers": {
        "no_servers": [
          { "text": "No servers registered yet. Add one via the Oz web dashboard or POST /api/servers.", "speech": "No servers registered yet." }
        ],
        "servers_list": [
          { "text": "{{ count }} registered server(s):<br><br>{{ servers }}", "speech": "Here are your registered servers." }
        ],
        "error": [
          { "text": "Couldn't fetch the server list: {{ message }}", "speech": "Couldn't fetch the server list." }
        ]
      }
    },
    "n8n_agent": {
      "answers": {
        "n8n_no_agents": [
          { "text": "No n8n agents are configured. Register one via the Oz API or dashboard.", "speech": "No n8n agents configured." }
        ],
        "n8n_ask_which": [
          { "text": "I found several n8n agents: {{ names }}. Which one should I use?", "speech": "Which n8n agent should I use? Available: {{ names }}." }
        ],
        "n8n_ask_confirm": [
          { "text": "I can use the <strong>{{ agent_name }}</strong> n8n agent for this ({{ description }}). Would you like me to?", "speech": "I can use the {{ agent_name }} n8n agent. Would you like me to?" }
        ],
        "n8n_working": [
          { "text": "Calling the <strong>{{ agent_name }}</strong> n8n agent...", "speech": "Calling the n8n agent. One moment." }
        ],
        "n8n_result": [
          { "text": "<div>{{ result }}</div>", "speech": "{{ result }}" }
        ],
        "error": [
          { "text": "Failed to call n8n agent: {{ message }}", "speech": "Failed to call n8n agent." }
        ]
      }
    }
  }
}
