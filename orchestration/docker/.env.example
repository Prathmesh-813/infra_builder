# Oz — Environment Configuration
# Copy this to .env and customize before running docker compose up

# Ports
OZ_WEB_PORT=3000
OZ_API_PORT=8000
LEON_PORT=5366

# Database
POSTGRES_USER=oz
POSTGRES_PASSWORD=oz
POSTGRES_DB=oz

# Security (change in production!)
SECRET_KEY=change-me-in-production

# LEON Settings
LEON_LANG=en-US
LEON_TIME_ZONE=UTC

# Command Code API Key (for commandcode agent)
# Get your API key from: https://commandcode.ai
COMMANDCODE_API_KEY=your-api-key-here

# Leon Command Code API Key (for Leon LLM processing)
# Get your API key from: https://commandcode.ai/settings/api-keys
LEON_COMMANDCODE_API_KEY=your-api-key-here
