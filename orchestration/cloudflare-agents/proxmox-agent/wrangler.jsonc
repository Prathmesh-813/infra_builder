{
  // Cloudflare Proxmox Agent
  // Manages Proxmox VE clusters — VMs, LXC containers, nodes, storage.
  // Deploy: wrangler deploy
  // Local dev: wrangler dev --remote (AI binding requires remote mode)
  // Auth: wrangler secret put AGENT_API_KEY  (Oz sends it as the x-api-key header)
  "name": "cf-proxmox-agent",
  "main": "src/index.ts",
  "compatibility_date": "2025-01-01",
  "compatibility_flags": ["nodejs_compat"],
  "ai": {
    "binding": "AI"
  },
  "observability": {
    "enabled": true
  },
  // VM provisioning polls clone/boot tasks for a while. Raise the CPU ceiling so
  // long flows don't get killed mid-provision (Workers Paid plan; ignored on Free).
  "limits": {
    "cpu_ms": 300000
  }
}
